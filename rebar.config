%% -*- mode: erlang -*-
%% rebar3 configuration for hecate_grid
%%
%% Layer-2 hecate-om service: a TSO open-data sensor. It polls near-real-time
%% grid datasets (Elia by default) and publishes each response VERBATIM as an
%% observation fact for hecate-archive to keep. Same pattern as hecate-warden and
%% hecate-news: observe the world, publish facts.
%%
%% STORELESS BY DESIGN: no store_id/0 + data_dir/0, so hecate_om:boot/1 wires the
%% mesh but starts NO reckon-db. The sensor is a producer only, and it does not
%% even parse what it fetches — parsing happens offline, against the archive,
%% where it can be re-run when it turns out to be wrong.

{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    %% The shared L2 substrate: mesh SDK + realm identity + capabilities +
    %% health. Brings macula transitively. HTTPS to the TSO endpoints uses pure
    %% OTP (inets + ssl + the system CA store) — no extra dep.
    {hecate_om, "~> 0.6"}
]}.

{project_plugins, [rebar3_ex_doc, rebar3_lint]}.

%% Elvis: the org's structural ruleset. No deep nesting (HARD, one level), no
%% nested try/catch, no if. Run via `rebar3 lint`.
{elvis, [
    {rulesets, #{
        macula_min => [
            {elvis_style, no_deep_nesting, #{level => 2}},
            {elvis_style, no_nested_try_catch, #{}},
            {elvis_style, no_if_expression, #{}}
        ]
    }},
    {config, [
        #{files => ["apps/*/src/**/*.erl"], ruleset => macula_min}
    ]}
]}.

{relx, [
    {release, {hecate_grid, "0.1.0"}, [hecate_grid, sasl]},
    {sys_config_src, "config/sys.config.src"},
    {vm_args_src,    "config/vm.args.src"},
    {extended_start_script, true}
]}.

{profiles, [
    {prod, [{relx, [{mode, prod},
                    {include_src, false},
                    {include_erts, true},
                    {debug_info, strip}]}]}
]}.

{dialyzer, [
    {warnings, [no_unknown]},
    {exclude_apps, [
        macula, macula_envy, macula_mdns,
        reckon_db, reckon_evoq, reckon_gater, evoq,
        khepri, ra, horus, aten, seshat, gen_batch_server,
        gproc, msgpack, cowboy, ranch, jsx
    ]}
]}.

{shell, [{apps, [hecate_grid]}]}.

{ex_doc, [
    {source_url, <<"https://codeberg.org/hecate-services/hecate-grid">>},
    {extras, ["README.md", "CHANGELOG.md", "LICENSE"]},
    {main, "README.md"}
]}.
